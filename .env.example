# Required: Secret key for signing JWT tokens (change this in production!)
JWT_SECRET=change-me-to-a-random-secret

# Optional: Override any config.yaml values via environment variables
# APP_TITLE=Seal
# APP_HOST=0.0.0.0
# APP_PORT=8000
# DATABASE_PATH=data/chat.lance
# AUTH_JWT_ALGORITHM=HS256
# AUTH_TOKEN_EXPIRE_MINUTES=1440

# Object storage: point DATABASE_PATH at a bucket URI and supply credentials
# either here (standard cloud env vars, read automatically by object_store) or
# via the `storage:` block in config.yaml.
#
# AWS S3 / S3-compatible (MinIO, Cloudflare R2, LocalStack):
# DATABASE_PATH=s3://my-bucket/chat.lance
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_ENDPOINT=http://localhost:4566   # custom endpoint for S3-compatible stores
# AWS_ALLOW_HTTP=true                  # allow plaintext HTTP to the endpoint
#
# Google Cloud Storage:
# DATABASE_PATH=gs://my-bucket/chat.lance
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# Azure Blob Storage:
# DATABASE_PATH=az://my-container/chat.lance
# AZURE_STORAGE_ACCOUNT_NAME=...
# AZURE_STORAGE_ACCOUNT_KEY=...
